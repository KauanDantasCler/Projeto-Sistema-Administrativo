generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model produto_promocao {
  id          BigInt    @id @default(autoincrement())
  produto_id  BigInt
  promocao_id BigInt
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  produtos    produtos  @relation(fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promocoes   promocoes @relation(fields: [promocao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}


model produtos {
  id               BigInt             @id @default(autoincrement())
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  nome             String             @db.VarChar
  descricao        String
  preco            Float
  ativo            Boolean
  updated_at       DateTime?          @db.Timestamptz(6)
  produto_promocao produto_promocao[]
}


model promocoes {
  id               BigInt             @id @default(autoincrement())
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  nome             String             @db.VarChar
  tipo_desconto    String             @db.VarChar
  valor_desconto   Float
  data_inicio      DateTime?          @db.Date
  data_fim         DateTime?          @db.Date
  ativo            Boolean
  updated_at       DateTime?          @db.Timestamptz(6)
  produto_promocao produto_promocao[]
}


model usuarios {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  nome       String    @db.VarChar
  cpf        String    @unique @db.VarChar
  email      String    @unique @db.VarChar
  senha_hash String    @db.VarChar
  perfil     String    @db.VarChar
  ativo      Boolean
  updated_at DateTime? @db.Timestamptz(6)
}